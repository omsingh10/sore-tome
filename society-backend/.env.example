# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string

# ─── Admin Login (hardcoded) ──────────────────────────
# Username: admin  |  Default password: 123123
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123123

# ─── Anthropic (Claude AI) ────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Firebase ─────────────────────────────────────────
FIREBASE_PROJECT_ID=sero-73976
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# ─── Society Info ─────────────────────────────────────
SOCIETY_NAME=Sunset Valley Society
SOCIETY_CITY=Mumbai

# ─── AI Providers ─────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
DEEPINFRA_API_KEY=your_deepinfra_api_key_here
FIREWORKS_API_KEY=your_fireworks_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
CEREBRAS_API_KEY=your-cerebras-key-here

# Cloudflare AI (Free Daily Tier)
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
CLOUDFLARE_API_TOKEN=your-api-token-here


# ─── Vector Database (PostgreSQL + pgvector) ──────────
DATABASE_URL=postgresql://user:password@localhost:5432/society_db

# ─── Redis (BullMQ / Caching) ────────────────────────
REDIS_URL=redis://localhost:6379
