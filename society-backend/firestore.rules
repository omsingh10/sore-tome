rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global function to check if user is authenticated and belongs to the society
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSameSociety(data) {
      return data.societyId == request.auth.token.societyId;
    }

    // Tenant Isolation Pattern: All collections must be partitioned by societyId
    match /{collection}/{docId} {
      
      allow read: if isAuthenticated() 
        && (resource == null || isSameSociety(resource.data));

      allow create: if isAuthenticated() 
        && isSameSociety(request.resource.data);

      allow update, delete: if isAuthenticated() 
        && isSameSociety(resource.data);
      
      // Sub-collections: Messages, Presence, etc.
      match /{subCollection}/{subDocId} {
        allow read, write: if isAuthenticated(); // Scoped by parent doc access in real apps usually
      }
    }

    // Special case for society_settings (Doc ID is societyId)
    match /society_settings/{societyId} {
      allow read: if isAuthenticated() && request.auth.token.societyId == societyId;
      allow write: if isAuthenticated() && request.auth.token.societyId == societyId && request.auth.token.role in ['admin', 'main_admin'];
    }
  }
}
